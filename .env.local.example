# ============================================================
# Investments Marc Platform — Variables de Entorno
# ============================================================
# Copiar a .env.local y rellenar con valores reales.
# NUNCA commitear .env.local — está en .gitignore.
# Para producción, estos valores van en GitHub Secrets.
#
# Guía completa: docs/guides/configuration.md
# ============================================================

# ── Firebase (Proyecto: investments-marc-prod) ───────────────
# Obtener de: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=investments-marc-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=investments-marc-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=investments-marc-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Sanity.io (Blog CMS) ────────────────────────────────────
# Obtener de: sanity.io/manage → Project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ── Stripe (Pagos — Fase 4) ─────────────────────────────────
# Obtener de: dashboard.stripe.com → Developers → API keys
# ⚠️ En dev usar test keys (pk_test_, sk_test_)
# ⚠️ En prod usar live keys (pk_live_, sk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── ConvertKit / Kit (Email Marketing — Fase 3) ─────────────
# Obtener de: app.convertkit.com → Settings → Advanced → API
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# ── WhatsApp Business API (Notificaciones — Fase 3) ─────────
WHATSAPP_NUMBER=18329534918
WHATSAPP_API_TOKEN=

# ── Site ─────────────────────────────────────────────────────
# En dev: http://localhost:3000
# En prod (GitHub Secret): https://investmentsmarc.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Firebase Emulators (solo desarrollo local) ───────────────
# Descomentar para usar emuladores en lugar de cloud:
# NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
