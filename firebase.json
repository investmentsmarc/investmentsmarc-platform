{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "predeploy": ["npm --prefix functions run build"],
      "ignore": ["node_modules", ".git", "*.log"]
    }
  ],
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/.next/**",
      "**/src/**",
      "**/docs/**",
      "*.md",
      ".env*"
    ],
    "appHosting": {
      "runtimeConfig": {
        "runtime": "nodejs20"
      }
    },
    "cleanUrls": true,
    "trailingSlashBehavior": "REMOVE"
  }
}
