{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/.next/**",
      "**/src/**",
      "**/docs/**",
      "*.md",
      ".env*"
    ],
    "appHosting": {
      "runtimeConfig": {
        "runtime": "nodejs20"
      }
    },
    "cleanUrls": true,
    "trailingSlashBehavior": "REMOVE"
  }
}
